@model Tyaran.BLL.ModelVM.Admin.AdminDashboardVm

<h2>Admin Dashboard</h2>

<div style="display:flex; gap:20px; margin-top:20px;">

    <div style="border:1px solid #ccc; padding:15px;">
        <h3>Users</h3>
        <p>@Model.UsersCount</p>
    </div>

    <div style="border:1px solid #ccc; padding:15px;">
        <h3>Deliveries</h3>
        <p>@Model.DeliveriesCount</p>
    </div>

    <div style="border:1px solid #ccc; padding:15px;">
        <h3>Restaurants</h3>
        <p>@Model.RestaurantsCount</p>
    </div>

    <div style="border:1px solid #ccc; padding:15px;">
        <h3>Orders</h3>
        <p>@Model.OrdersCount</p>
    </div>

</div>

<hr />

