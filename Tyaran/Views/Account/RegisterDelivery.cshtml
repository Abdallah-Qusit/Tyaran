@model Tyaran.BLL.ModelVM.ViewModels.RegisterDeliveryViewModel

<h2>Register Delivery (Test)</h2>

<form asp-action="RegisterDelivery" method="post" enctype="multipart/form-data">

    <div asp-validation-summary="All" class="text-danger"></div>

    <div>
        <label>Name</label><br />
        <input asp-for="Name" />
        <span asp-validation-for="Name"></span>
    </div>

    <div>
        <label> (Username)</label><br />
        <input asp-for="Username" />
        <span asp-validation-for="Username"></span>
    </div>
    <div>
        <label> Email</label><br />
        <input asp-for="Email" />
        <span asp-validation-for="Email"></span>
    </div>

    <div>
        <label>Phone</label><br />
        <input asp-for="Phone" />
        <span asp-validation-for="Phone"></span>
    </div>

    <div>
        <label>Vehicle Type</label><br />
        <input asp-for="VehicleType" />
        <span asp-validation-for="VehicleType"></span>
    </div>

    <div>
        <label>National ID File</label><br />
        <input asp-for="NationalIdFile" type="file"/>
        <span asp-validation-for="NationalIdFile"></span>
    </div>

    <div>
        <label>Password</label><br />
        <input asp-for="Password" type="password" />
        <span asp-validation-for="Password"></span>
    </div>

    <div>
        <label>Confirm Password</label><br />
        <input asp-for="ConfirmPassword" type="password" />
        <span asp-validation-for="ConfirmPassword"></span>
    </div>

    <br />

    <button type="submit">Register Delivery</button>

</form>

<hr />

<a asp-action="Login">Already registered? Login</a>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}