@model Tyaran.BLL.ModelVM.ViewModels.ChangePasswordViewModel

<h2>Change Password</h2>

<form asp-action="ChangePassword" method="post">

    <div asp-validation-summary="All" class="text-danger"></div>

    <div>
        <label>Current Password</label><br />
        <input asp-for="CurrentPassword" type="password" />
        <span asp-validation-for="CurrentPassword"></span>
    </div>

    <div>
        <label>New Password</label><br />
        <input asp-for="NewPassword" type="password" />
        <span asp-validation-for="NewPassword"></span>
    </div>

    <div>
        <label>Confirm New Password</label><br />
        <input asp-for="ConfirmNewPassword" type="password" />
        <span asp-validation-for="ConfirmNewPassword"></span>
    </div>

    <br />

    <button type="submit">Change Password</button>

</form>

@if (ViewBag.Success != null)
{
    <p style="color:green">@ViewBag.Success</p>
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
