@model Tyaran.DAL.Entities.Generated.MenuItem

<h1>Create Menu Item</h1>

<form asp-action="Create"
      method="post"
      enctype="multipart/form-data">

    <div class="mb-3">
        <label>Name</label>
        <input asp-for="Name" class="form-control" />
    </div>

    <div class="mb-3">
        <label>Description</label>
        <textarea asp-for="Description"
                  class="form-control"></textarea>
    </div>

    <div class="mb-3">
        <label>Image</label>
        <input type="file"
               name="imageFile"
               class="form-control" />
    </div>

    <div class="mb-3">
        <label>Price</label>
        <input asp-for="Price"
               class="form-control" />
    </div>

    <div class="mb-3">
        <label>Preparation Time</label>
        <input asp-for="PreparationTime"
               class="form-control" />
    </div>

    <div class="mb-3">
        <label>Category ID</label>
        <input asp-for="MenuCatId"
               class="form-control" />
    </div>

    <button type="submit"
            class="btn btn-success">
        Create
    </button>
</form>